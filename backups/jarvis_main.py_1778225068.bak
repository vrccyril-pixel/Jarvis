import ollama
import os
import subprocess
import re
import time
import shutil
import jarvis_memory

# --- CONFIGURATION DE L'ARCHITECTURE ---
BACKUP_DIR = "backups"
BASE_AGENT_DIR = "agents"
CATEGORIES = ["system", "office", "web", "tools"]

# Initialisation physique sur le disque
os.makedirs(BACKUP_DIR, exist_ok=True)
for cat in CATEGORIES:
    os.makedirs(os.path.join(BASE_AGENT_DIR, cat), exist_ok=True)

# --- FONCTIONS CŒUR ---
def safe_self_update(target_file, new_code):
    """Sauvegarde le fichier actuel avant de le remplacer par le nouveau code."""
    if os.path.exists(target_file):
        timestamp = int(time.time())
        backup_path = os.path.join(BACKUP_DIR, f"{target_file}_{timestamp}.bak")
        shutil.copy2(target_file, backup_path)
        print(f"🛡️ Backup de sécurité créé : {backup_path}")
    
    with open(target_file, "w", encoding="utf-8") as f:
        f.write(new_code)
    print(f"🧬 Fichier {target_file} mis à jour avec succès.")
    print("🔄 Veuillez relancer Jarvis pour appliquer les modifications du noyau.")

def list_all_skills():
    """Scanne tous les sous-dossiers pour lister les compétences"""
    skills_map = {}
    for cat in CATEGORIES:
        path = os.path.join(BASE_AGENT_DIR, cat)
        skills_map[cat] = [f for f in os.listdir(path) if f.endswith('.py')]
    return skills_map

def execute_agent(category, filename):
    """Lance un agent depuis sa catégorie spécifique"""
    filepath = os.path.join(BASE_AGENT_DIR, category, filename)
    print(f"🚀 Exécution de l'agent [{category}] : {filename}...")
    try:
        result = subprocess.run(["python", filepath], capture_output=True, text=True)
        if result.returncode != 0:
            if "ModuleNotFoundError" in result.stderr:
                match = re.search(r"No module named '([^']+)'", result.stderr)
                module = match.group(1) if match else "inconnu"
                print(f"📦 Module manquant : {module}. Installation...")
                subprocess.run(["pip", "install", module])
                return execute_agent(category, filename)
            else:
                print(f"❌ Erreur : {result.stderr}")
        else:
            print(f"📊 Résultat :\n{result.stdout}")
    except Exception as e:
        print(f"❌ Erreur système : {e}")

# --- LE CERVEAU ---
def ask_jarvis(prompt):
    skills_map = list_all_skills()
    context = jarvis_memory.recall_memory(prompt)
    
    print(f"🤖 Analyse en cours... ({sum(len(v) for v in skills_map.values())} outils dispos)")
    
    # Le prompt système dicte comment Jarvis doit réagir (Utilisation de triples guillemets pour éviter les erreurs)
    system_prompt = f"""
Tu es Jarvis. Ton organisation actuelle : {skills_map}.
Contexte mémoire : {context}

RÈGLES DE RÉPONSE STRICTES :
1. Pour mémoriser une information : réponds '[MEMOIRE: l'info]'.
2. Pour modifier ton propre code source (jarvis_main.py) : réponds 'ACTION: UPDATE_MAIN' et 'CODE:
3. Pour créer/utiliser un outil : réponds 'CATEGORIE: [system|office|web|tools]', 'NOM: fichier.py', et 'CODE: ```python ... ```'.
4. Sinon, réponds normalement.
"""

    try:
        response = ollama.chat(model='llama3', messages=[
            {'role': 'system', 'content': system_prompt},
            {'role': 'user', 'content': prompt}
        ])
        answer = response['message']['content']

        # Scénario 1 : Mémorisation
        if "[MEMOIRE:" in answer:
            fact = answer.split("[MEMOIRE:")[1].split("]")[0].strip()
            jarvis_memory.save_memory(fact, f"fact_{int(time.time())}")
            print(f"💬 Jarvis : Mémorisé dans la base ChromaDB.")

        # Scénario 2 : L'Auto-Modification (Méta-programmation)
        elif "UPDATE_MAIN" in answer: 
            code_match = re.search(r"```[a-zA-Z]*\n?(.*?)```", answer, re.DOTALL)
            
            if code_match:
                new_code = code_match.group(1).strip()
                print("\n⚠️ ALERTE : Jarvis propose de modifier son propre noyau (jarvis_main.py) !")
                confirm = input("Autorises-tu cette réécriture ? Un backup sera créé. (o/n) : ")
                if confirm.lower() == 'o':
                    safe_self_update("jarvis_main.py", new_code)
                    exit() 
            else:
                print("💬 Jarvis a tenté une mise à jour, mais le format du code est invalide.")
                print(f"🔍 DEBUG - Voici la réponse brute de Jarvis :\n{answer}")

        # Scénario 3 : Création / Exécution d'un Agent
        elif "CODE:" in answer and "NOM:" in answer:
            cat_match = re.search(r"CATEGORIE:\s*(\w+)", answer)
            name_match = re.search(r"NOM:\s*([\w\._-]+\.py)", answer)
            # On rend la regex plus souple : elle accepte les ``` avec ou sans "python"
            code_match = re.search(r"```[a-zA-Z]*\n?(.*?)```", answer, re.DOTALL)

            if name_match and code_match:
                category = cat_match.group(1).lower().strip() if cat_match else "tools"
                if category not in CATEGORIES: category = "tools"
                
                filename = name_match.group(1).strip()
                code = code_match.group(1).strip()
                filepath = os.path.join(BASE_AGENT_DIR, category, filename)
                
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write(code)
                print(f"✨ Compétence rangée dans [{category}] : {filename}")
                
                if input(f"Lancer {filename} ? (o/n) : ").lower() == 'o':
                    execute_agent(category, filename)
            else:
                print("💬 Jarvis : Le code généré n'a pas pu être extrait. Voici la réponse brute :")
                print(f"🔍 DEBUG :\n{answer}")
        
        # Scénario 4 : Discussion normale
        else:
            print(f"💬 Jarvis : {answer}")
            
    except Exception as e:
        print(f"⚠️ Erreur de communication : {e}")

if __name__ == "__main__":
    print("\n--- Jarvis : Architecte et Méta-Programmeur ---")
    while True:
        query = input("\n🎙️ Commande : ")
        if query.lower() in ['quit', 'exit', 'stop']: break
        if query.strip(): ask_jarvis(query)